!AUTOMATON
name: akari-kittentts
version: 1.0.0
description: KittenTTS Engine
author: AkariNet
priority: 150
respondsto: tts_request
controls: say
code>
module.exports.default = {
  async setup() {
    try {
        const { KittenTTS } = await import('https://76836.github.io/AkariNet-KittenTTS/AkariNet-KittenTTS-1.0.0.js');
        window.initTTS({
            voiceUrl: 'https://76836.github.io/AkariNet-KittenTTS/default.bin',
            speed: 1.123,
            concurrency: 2,
            segmentMax: 220,
            debug: false
        });
    } catch(e) { console.error("KittenTTS init error", e); }

    on('tts_request', (event) => {
      let index = parseInt(localStorage.getItem('index_akari-kittentts'));
      if (isNaN(index)) index = 150;
      
      event.apply(async () => {
          if (event.source === 'text') return; // Do not speak typed inputs
          if (window.tts && window.tts.isReady) {
              window.tts.speak(event.text);
          }
      }, index);
    });
  }
};
