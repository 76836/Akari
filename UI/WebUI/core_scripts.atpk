!AUTOMATON
name: akari-pollinations
version: 1.0.0
description: Pollinations AI Provider (Always available)
author: AkariNet
priority: 100
respondsto: message_sent
controls: say
code>
module.exports.default = {
  setup() {
    let history = [{ role: 'system', content: 'Your name is Akari, an AI girl.' }];
    
    on('message_sent', (event) => {
      // Always volunteer if online
      if (!navigator.onLine) return;
      
      let index = parseInt(localStorage.getItem('index_akari-pollinations'));
      if (isNaN(index)) index = 100;
      
      event.apply(async () => {
          history.push({ role: 'user', content: event.message });
          if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('processing');
          
          try {
              const res = await fetch('https://text.pollinations.ai/', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ messages: history, model: 'openai' })
              });
              if (res.ok) {
                  const text = await res.text();
                  history.push({ role: 'assistant', content: text });
                  if (history.length > 20) history.splice(0, 2);
                  say(text, event.source);
              } else {
                  say("[ERROR] Akari's connection flickered...", event.source);
              }
          } catch (e) {
              say("[ERROR] NO_CARRIER_SIGNAL", event.source);
          }
          if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('idle');
      }, index);
    });
  }
};
<code

!AUTOMATON
name: akari-gemini
version: 1.6.0
description: Google Gemini AI Provider (Requires API Key)
author: AkariNet
priority: 110
respondsto: message_sent
controls: say
code>
module.exports.default = {
  setup() {
    let chat = null;
    let initialized = false;
    let cachedApiKey = localStorage.getItem('genAI_API_KEY');

    async function initGemini() {
        const apiKey = localStorage.getItem('genAI_API_KEY');
        if (!apiKey) return false;
        try {
            const { GoogleGenerativeAI } = await import("https://esm.run/@google/generative-ai");
            const genAI = new GoogleGenerativeAI(apiKey);
            const model = genAI.getGenerativeModel({ model: "gemini-2.5-flash" });
            chat = model.startChat({ history: [] });
            initialized = true;
            cachedApiKey = apiKey;
            return true;
        } catch(e) { return false; }
    }

    on('message_sent', (event) => {
      const currentKey = localStorage.getItem('genAI_API_KEY');
      if (!currentKey) return; // Don't apply if no key
      
      if (currentKey !== cachedApiKey) { initialized = false; } // Re-init if key changed

      let index = parseInt(localStorage.getItem('index_akari-gemini'));
      if (isNaN(index)) index = 110;
      
      event.apply(async () => {
          if (!initialized) {
              const ok = await initGemini();
              if (!ok) {
                  say("Gemini initialization failed.", event.source);
                  return;
              }
          }
          if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('processing');
          try {
              const result = await chat.sendMessage(event.message);
              const response = await result.response;
              say(response.text(), event.source);
          } catch(e) {
              say("Gemini Error: " + e.message, event.source);
          }
          if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('idle');
      }, index);
    });
  }
};
