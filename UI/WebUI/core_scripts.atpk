!AUTOMATON
name: akari-lcpp
version: 1.3.0
description: Llama.cpp Local AI Provider (Requires connected server)
author: AkariNet
priority: 120
respondsto: message_sent
controls: say
code>
module.exports.default = {
  setup() {
    let history = [{ role: 'system', content: 'Your name is Akari, an AI girl.' }];
    
    function getServer() {
      try {
        const servers = JSON.parse(localStorage.getItem('lcpp_servers') || '[]');
        return servers.find(s => s.online) || null;
      } catch(e) { return null; }
    }

    on('message_sent', (event) => {
      const server = getServer();
      if (!server) return; // Don't apply if no active server
      
      let index = parseInt(localStorage.getItem('index_akari-lcpp'));
      if (isNaN(index)) index = 120;
      
      event.apply(async () => {
          history.push({ role: 'user', content: event.message });
          if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('processing');

          try {
              const res = await fetch(`${server.url}/v1/chat/completions`, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                      model: 'local',
                      messages: history,
                      max_tokens: 1000,
                      stream: false
                  })
              });
              const data = await res.json();
              let text = data?.choices?.[0]?.message?.content;
              if (text) {
                  text = text.replace(/<\/?s>|<\|end(?:_of_turn|_of_text)?\|>|<\|eot_id\|>/g, '').trim();
                  history.push({ role: 'assistant', content: text });
                  say(text, event.source);
              }
          } catch (err) {
              say(`⚠️ Connection error: ${err.message}`, event.source);
              history.pop();
          }
          if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('idle');
      }, index);
    });
  }
};
