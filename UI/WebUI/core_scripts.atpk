!AUTOMATON
name: akari-webspeechtts
version: 1.0.0
description: Fallback Browser TTS Engine
author: AkariNet
priority: 10
respondsto: tts_request
code>
module.exports.default = {
  setup() {
    if (!('speechSynthesis' in window)) return;
    
    on('tts_request', (event) => {
      let index = parseInt(localStorage.getItem('index_akari-webspeechtts'));
      if (isNaN(index)) index = 10;

      event.apply(async () => {
          if (event.source === 'text') return; // Do not speak typed inputs
          const utterance = new SpeechSynthesisUtterance(event.text);
          window.speechSynthesis.speak(utterance);
      }, index);
    });
  }
};
<code

!AUTOMATON
name: akari-webspeechstt
version: 1.0.0
description: Fallback Browser Speech Recognition
author: AkariNet
priority: 10
respondsto: voice_toggle_on, voice_toggle_off
code>
module.exports.default = {
  setup() {
    if (!('webkitSpeechRecognition' in window)) return;
    
    let recognition = new webkitSpeechRecognition();
    recognition.continuous = false;
    recognition.interimResults = false;
    
    recognition.onresult = (e) => {
        const text = e.results[0][0].transcript;
        if (window.bubble_incoming) window.bubble_incoming(text);
        if (window.requestHandling) window.requestHandling('message_sent', { message: text, source: 'voice' });
        if (window.toggleVoice) window.toggleVoice(); // turn off mic
    };

    on('voice_toggle_on', (event) => {
        try { recognition.start(); } catch(e){}
    });
    
    on('voice_toggle_off', (event) => {
        recognition.stop();
    });
  }
};
<code

!AUTOMATON
name: akari-audioconsole
version: 3.4.0
description: Audio Console for advanced STT
author: AkariNet
priority: 150
respondsto: boot
controls: emit
code>
module.exports.default = {
  async setup() {
      try {
          const { AkarinetVoice } = await import('https://76836.github.io/AkariNet-AudioConsole/audioConsole-3.4.0.js');
          const config = {
              modelId: "onnx-community/moonshine-base-ONNX",
              modelQuantization: "q8",
              wakesoundThreshold: parseFloat(localStorage.getItem('wakeSense') || "0.80"),
              requireWakeSound: true
          };
          const assistant = new AkarinetVoice(config);
          
          assistant.addEventListener('result', (e) => {
              if (window.bubble_incoming) window.bubble_incoming(e.detail.text);
              window.requestHandling('message_sent', { message: e.detail.text, source: 'voice' });
          });

          assistant.addEventListener('speechstart', () => {
              if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('active', 'listening');
          });

          assistant.addEventListener('speechend', () => {
              if (typeof window.setVoiceStatus === 'function') window.setVoiceStatus('idle');
          });
          
          await assistant.init();
      } catch(e) {}
  }
};
<code
