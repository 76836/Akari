atpk-name: akari-core-scripts
atpk-description: Ported legacy scripts into Automata System

!AUTOMATON
name: akari-reflex
version: 1.0.0
description: Default reflexive response script
author: AkariNet
priority: 200
respondsto: message_sent
controls: say, showNotification
code>
module.exports.default = {
  setup() {
    on('message_sent', (event) => {
      let index = parseInt(localStorage.getItem('index_akari-reflex'));
      if (isNaN(index)) index = 200;

      const outcome = event.message.toLowerCase();
      const shouldHandle = 
          (outcome.includes("exit")) ||
          (outcome.includes("solve ")) ||
          (outcome.includes("time") && outcome.includes("what")) ||
          (outcome.includes("what") && outcome.includes("up")) ||
          (outcome.includes("who") && outcome.includes("you")) ||
          (outcome.includes("weather") && outcome.includes("what")) ||
          (outcome.includes("open")) ||
          (outcome.includes("youtube")) ||
          (outcome.includes("search"));

      if (shouldHandle) {
          event.apply(async () => {
              if (outcome.includes("exit")) { say("Shutting down", event.source); return; }
              if (outcome.includes("solve ")) {
                  const mathExpression = outcome.replace("solve", "").replace(/[^-()\d/*+.]/g, '');
                  try {
                      const result = new Function(`return ${mathExpression}`)();
                      say(result.toString(), event.source);
                  } catch(e) { say("Error solving math.", event.source); }
                  return;
              }
              if (outcome.includes("time") && outcome.includes("what")) {
                  say('The time is... ' + new Date().toLocaleTimeString(), event.source);
                  return;
              }
              if (outcome.includes("what") && outcome.includes("up")) {
                  say('Akari Framework Automata Edition!', event.source);
                  return;
              }
              if (outcome.includes("who") && outcome.includes("you")) {
                  say("I'm Akari.", event.source);
                  return;
              }
              if (outcome.includes("weather") && outcome.includes("what")) {
                  say("I can't access weather, try searching Bing.", event.source);
                  return;
              }
              say("I have intercepted this command but have not fully implemented its legacy logic yet.", event.source);
          }, index);
      }
    });
  }
};
